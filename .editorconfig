root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown: dos espacios al final pueden ser line breaks intencionales
[*.md]
trim_trailing_whitespace = false

# Makefiles requieren tabs literales
[Makefile]
indent_style = tab
